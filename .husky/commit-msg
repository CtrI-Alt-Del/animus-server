#!/bin/sh

if ! command -v node >/dev/null 2>&1; then
  export NVM_DIR="$HOME/.nvm"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
  fi
fi

if ! command -v node >/dev/null 2>&1; then
  echo "Node.js not found in hook environment. Ensure Node is installed and available in PATH."
  exit 1
fi

./node_modules/.bin/commitlint --edit "$1"
